{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "@/components": ["src/components"],
      "@/ui/*": ["src/components/ui/*"],
      "@/hooks/*": ["src/hooks/*"],
      "@/hooks": ["src/hooks"],
      "@/lib/*": ["src/lib/*"],
      "@/lib": ["src/lib"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "build", ".next"]
}
