<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Mahdimonir Portfolio Notification</title>
    <style>
        body {
            background-color: #f9fafb;
            font-family: "Inter", system-ui, sans-serif;
            color: hsl(222.2, 47.4%, 11.2%);
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 600px;
            margin: 40px auto;
            background-color: hsl(0, 0%, 100%);
            border-radius: 12px;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }

        .header {
            background-color: hsl(222.2, 47.4%, 11.2%);
            color: hsl(210, 40%, 98%);
            padding: 24px;
            text-align: center;
        }

        .header h1 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
        }

        .body {
            padding: 32px;
        }

        .body p {
            font-size: 16px;
            line-height: 1.6;
            margin-bottom: 20px;
        }

        .otp {
            font-size: 32px;
            font-weight: bold;
            color: hsl(222.2, 100%, 60%);
            text-align: center;
            background-color: hsl(210, 40%, 96.1%);
            padding: 12px 20px;
            border-radius: 8px;
            letter-spacing: 2px;
        }

        .footer {
            background-color: hsl(210, 40%, 96.1%);
            padding: 24px;
            text-align: center;
            font-size: 14px;
            color: hsl(215.4, 16.3%, 46.9%);
        }

        .footer a {
            color: hsl(210, 90%, 60%);
            text-decoration: none;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <h1>Mahdimonir Portfolio</h1>
        </div>
        <div class="body">
            <p>Hello <%= name %>,</p>

            <% if (type==="activation" ) { %>
                <p>Thank you for registering on my portfolio. Use the following OTP to verify your account:</p>
                <div class="otp">
                    <%= otp %>
                </div>
                <p>This code will expire in 30 minutes.</p>
                <% } else if (type==="login" ) { %>
                    <p>We received a request to log into your account on my portfolio.</p>
                    <p>Please use the following OTP to complete your login:</p>
                    <div class="otp">
                        <%= otp %>
                    </div>
                    <p>This code is valid for the next 30 minutes. If you did not initiate this request, please ignore
                        this email or reset your password immediately.</p>
                    <% } else if (type==="passwordReset" ) { %>
                        <p>You requested to reset your password. Use this OTP:</p>
                        <div class="otp">
                            <%= otp %>
                        </div>
                        <p>This code will expire in 5 minutes.</p>
                        <p>If you did not request a password reset, please ignore this email.</p>
                        <% } else if (type==="resendOtp" ) { %>
                            <p>You requested to resend your OTP. Here it is:</p>
                            <div class="otp">
                                <%= otp %>
                            </div>
                            <p>This code will expire in 5 minutes.</p>
                            <p>If you did not request a resend of your OTP, please
                                ignore this email.</p>
                            <% } else if (type==="msg-reply" ) { %>
                                <p>
                                    <%= message %>
                                </p>
                                <p>Thank you for your message. I will get back to you soon.</p>
                                <p>Best regards,<br>Moniruzzaman Mahdi</p>
                                <% } else { %>
                                    <p>
                                        <%= message %>
                                    </p>
                                    <div class="otp">
                                        <%= otp %>
                                    </div>
                                    <% } %>
        </div>
        <div class="footer">
            Questions? Contact <a href="mailto:mahdimoniruzzaman@gmail.com">mahdimoniruzzaman@gmail.com</a>
        </div>
    </div>
</body>

</html>